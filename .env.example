# Copy this file to .env.local and fill in your values
# Never commit .env.local

# Supabase — get from supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Claude API — server-side only (used in Edge Functions, not here)
# CLAUDE_API_KEY=your-claude-api-key  DO NOT add VITE_ prefix

# App
VITE_APP_NAME=WellNest
VITE_APP_URL=http://localhost:5173

# Feature Flags (v2.1)
VITE_ENABLE_IMAGING=true
VITE_ENABLE_CONDITION_WEB=true
VITE_ENABLE_POSTURE_TRACKER=true
VITE_POSTURE_REMINDER_INTERVAL_MINUTES=45
